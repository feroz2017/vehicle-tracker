# ── Waltti GTFS-RT ────────────────────────────────────────────────────────────
# Obtain from: https://www.waltti.fi/developer  (or team lead)
WALTTI_API_KEY=your-waltti-api-key-here
WALTTI_BASE_URL=https://api.waltti.fi/v2/authority/jyvaskyla

# ── Digitransit ───────────────────────────────────────────────────────────────
# Obtain from: https://portal-api.digitransit.fi  (register → subscribe)
DIGITRANSIT_API_KEY=your-digitransit-api-key-here
DIGITRANSIT_BASE_URL=https://api.digitransit.fi

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running locally without Docker:  redis://localhost:6379
# When running inside Docker Compose:   redis://redis:6379  (set in compose file)
REDIS_URL=redis://localhost:6379

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_VEHICLES=60
CACHE_TTL_PLAN=300
CACHE_TTL_GEO=86400
CACHE_TTL_ALERTS=60

# ── Freshness thresholds (seconds) ───────────────────────────────────────────
FRESHNESS_LIVE_MAX=60
FRESHNESS_DELAYED_MAX=120

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_INTERVAL=30
