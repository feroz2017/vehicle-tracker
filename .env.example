# ── Waltti GTFS-RT ────────────────────────────────────────────────────────────
# Auth: HTTP Basic Auth — id:secret
# Register at: https://data.waltti.fi  or contact waltti.fi for access
WALTTI_ID=your-waltti-id
WALTTI_SECRET=your-waltti-secret
WALTTI_BASE_URL=https://data.waltti.fi/jyvaskyla/api/gtfsrealtime/v1.0/feed

# ── Digitransit ───────────────────────────────────────────────────────────────
# Register at: https://portal-api.digitransit.fi
# Header used: digitransit-subscription-key
DIGITRANSIT_API_KEY=your-digitransit-api-key
DIGITRANSIT_BASE_URL=https://api.digitransit.fi

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (no Docker):  redis://localhost:6379
# Inside Docker Compose:  redis://redis:6379  (overridden in docker-compose.yml)
REDIS_URL=redis://localhost:6379

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
VEHICLE_CACHE_TTL=60
PLAN_CACHE_TTL=300
GEO_CACHE_TTL=86400
ALERTS_CACHE_TTL=60

# ── Freshness thresholds (seconds) ───────────────────────────────────────────
DELAYED_THRESHOLD=60
STALE_THRESHOLD=120

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_INTERVAL=30
